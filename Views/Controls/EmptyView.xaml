<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CollectionManagementSystem.Views.Controls.EmptyView"
             x:Name="self">
    <StackLayout HorizontalOptions="Center" VerticalOptions="Center" BindingContext="{x:Reference self}">
        <Label Text="{Binding Title}" FontSize="Medium" TextColor="Gray" />
        <Button Text="{Binding ButtonText}" Command="{Binding ButtonCommand}" Margin="0,16,0,0" HorizontalOptions="Center"/>
    </StackLayout>
</ContentView>
