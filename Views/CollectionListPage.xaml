<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CollectionManagementSystem.ViewModels"
             x:Class="CollectionManagementSystem.Views.CollectionListPage"
             x:DataType="viewModels:CollectionListViewModel"
             Title="{Binding Title}">

    <Grid Padding="20">
        <CollectionView x:Name="ItemsCollectionView"
                        ItemsSource="{Binding SortedItems}"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged"
                        ItemTemplate="{StaticResource CollectionItemRowTemplate}"
                        EmptyView="Brak elementów w tej kolekcji." />
    </Grid>
</ContentPage>
