<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CollectionManagementSystem.ViewModels"
             x:Class="CollectionManagementSystem.Views.SummaryPage"
             x:DataType="viewModels:SummaryViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Wszystkie elementy" />
                    <Label Grid.Column="1" Text="{Binding TotalItems}" FontAttributes="Bold" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Posiadane / używane / nowe" />
                    <Label Grid.Column="1" Text="{Binding OwnedItems}" FontAttributes="Bold" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Sprzedane" />
                    <Label Grid.Column="1" Text="{Binding SoldItems}" FontAttributes="Bold" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Na sprzedaż" />
                    <Label Grid.Column="1" Text="{Binding ForSaleItems}" FontAttributes="Bold" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Chcę kupić" />
                    <Label Grid.Column="1" Text="{Binding WantToBuyItems}" FontAttributes="Bold" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Średnia ocena" />
                    <Label Grid.Column="1" Text="{Binding AverageRating, StringFormat='{}{0:0.0}/10'}" FontAttributes="Bold" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SummaryCardStyle}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Łączna szacowana wartość" />
                    <Label Grid.Column="1" Text="{Binding EstimatedValue, StringFormat='{}{0:0.00} zł'}" FontAttributes="Bold" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
