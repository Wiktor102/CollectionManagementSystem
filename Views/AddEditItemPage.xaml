<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CollectionManagementSystem.ViewModels"
             xmlns:converters="clr-namespace:CollectionManagementSystem.Converters"
             x:Class="CollectionManagementSystem.Views.AddEditItemPage"
             x:DataType="viewModels:AddEditItemViewModel"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="20">
                        <VerticalStackLayout Spacing="10" Grid.Column="0" HorizontalOptions="Start">
                            <Label Text="Zdjęcie" Style="{StaticResource SectionHeaderLabelStyle}" />
                            <Grid HeightRequest="180" WidthRequest="180">
                                <Image Source="{Binding ImagePreviewPath}"
                                       Aspect="AspectFit"
                                       IsVisible="{Binding HasImage}" />
                                <Button Text="Wybierz obraz"
                                        Command="{Binding PickImageCommand}"
                                        IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}}"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                            </Grid>
                            <Button Text="Zmień obraz"
                                    Command="{Binding PickImageCommand}"
                                    IsVisible="{Binding HasImage}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout  Grid.Column="1">
                            <Label Text="Nazwa" Margin="0,0,0,4"/>
                            <Entry Text="{Binding Name}" Placeholder="Nazwa elementu" />

                            <Label Text="Status" Margin="0,10,0,4" />
                            <Picker ItemsSource="{Binding StatusOptions}"
                                    SelectedItem="{Binding SelectedStatus}"
                                    ItemDisplayBinding="{Binding Label}" />

                            <Label Text="Cena" Margin="0,10,0,4" />
                            <Entry Text="{Binding PriceInput}" Keyboard="Numeric" Placeholder="0.00" />

                            <Label Text="{Binding RatingDisplayText}" Margin="0,10,0,-4" />
                            <Slider Minimum="1" Maximum="10" Value="{Binding Rating}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Komentarz" Margin="0,10,0,4" />
                    <Editor Text="{Binding Comment}" AutoSize="TextChanges" Placeholder="Uwagi" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" IsVisible="{Binding HasCustomFields}">
                <VerticalStackLayout Spacing="10"
                                     BindableLayout.ItemsSource="{Binding CustomFieldEditors}">
                    <Label Text="Pola niestandardowe" Style="{StaticResource SectionHeaderLabelStyle}" />
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:CustomFieldEditorViewModel">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="4">
                                <Label Text="{Binding ColumnName}" FontAttributes="Bold" />
                                <Entry Grid.Row="1"
                                       Text="{Binding Value}"
                                       IsVisible="{Binding IsText}" />
                                <Entry Grid.Row="1"
                                       Text="{Binding Value}"
                                       Keyboard="Numeric"
                                       IsVisible="{Binding IsNumber}" />
                                <Picker Grid.Row="1"
                                        ItemsSource="{Binding AllowedValues}"
                                        SelectedItem="{Binding Value}"
                                        IsVisible="{Binding IsValueSet}" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="Anuluj" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                <Button Grid.Column="1" Text="Zapisz" Command="{Binding SaveCommand}" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
